# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=password_here
DB_NAME=ocs_booking

# JWT — must be at least 32 random characters
JWT_SECRET=long_random_secret_string

# Seeded admin account (created on first run if no admin exists)
ADMIN_EMAIL=admin@ocs.iith.ac.in
ADMIN_PASSWORD=change_this_admin_password

# Server port
PORT=8080
